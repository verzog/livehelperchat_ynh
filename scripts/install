#!/bin/bash

set -u
source _common.sh
source /usr/share/yunohost/helpers
ynh_abort_if_errors

# DOWNLOAD, CHECK AND UNPACK SOURCE
ynh_script_progression "Setting up source files..."

ynh_setup_source --dest_dir="$install_dir"

# The tarball extracts to install_dir/lhc_web/ — move contents up one level
if [ -d "$install_dir/lhc_web" ]; then
    shopt -s dotglob
    mv "$install_dir/lhc_web"/* "$install_dir/" 2>/dev/null || true
    shopt -u dotglob
    rm -rf "$install_dir/lhc_web"
fi

chown -R "$app:www-data" "$install_dir"

# Ensure install_dir and all subdirs are readable/writable by app user
# (YunoHost provision sets restrictive perms that chown alone doesn't fix)
chmod 755 "$install_dir"
chmod -R u+rw,g-w,o-rwx "$install_dir"

# SET FOLDER PERMISSIONS
ynh_script_progression "Setting folder permissions..."

# YunoHost standard: 770 for writable dirs (rwxrwx---)
# Allows both $app user and www-data (PHP) to read/write
# 750 for base dir already set above (rwxr-x---)
chmod 770 "$install_dir/settings/"
chmod 770 "$install_dir/var/"
chmod -R 770 "$install_dir/var/storage"
chmod -R 770 "$install_dir/var/userphoto"
chmod -R 770 "$install_dir/var/storageform"
chmod -R 770 "$install_dir/var/storageadmintheme"
chmod -R 770 "$install_dir/var/botphoto"
chmod -R 770 "$install_dir/var/bottrphoto"
chmod -R 770 "$install_dir/var/storageinvitation"
chmod -R 770 "$install_dir/var/storagedocshare"
chmod -R 770 "$install_dir/var/storagetheme"
chmod -R 770 "$install_dir/var/tmpfiles"
chmod -R 770 "$install_dir/cache/"

# PHP-FPM CONFIGURATION
ynh_script_progression "Configuring PHP-FPM..."

mkdir -p "/etc/php/$php_version/fpm/pool.d"
cp "../conf/php-fpm.conf" "/etc/php/$php_version/fpm/pool.d/$app.conf"
apply_template "/etc/php/$php_version/fpm/pool.d/$app.conf"

# Validate config before reloading to avoid breaking other sites
php-fpm${php_version} --test 2>/dev/null \
    || { rm -f "/etc/php/$php_version/fpm/pool.d/$app.conf"; ynh_die "PHP-FPM config test failed — pool config removed to protect other sites."; }

systemctl reload "php${php_version}-fpm"

# NGINX CONFIGURATION
ynh_script_progression "Configuring NGINX web server..."

mkdir -p "/etc/nginx/conf.d/$domain.d"
cp "../conf/nginx.conf" "/etc/nginx/conf.d/$domain.d/$app.conf"
apply_template "/etc/nginx/conf.d/$domain.d/$app.conf"

systemctl reload nginx

# CLI INSTALLATION
ynh_script_progression "Running CLI installation..."

# Patch upstream PHP parse errors in cli/lib/install.php
# (LHC 4.84v ships with two `$Errors = []` lines missing trailing semicolons)
sed -i 's/^\(\s*\$Errors = \[\]\)$/\1;/' "$install_dir/cli/lib/install.php"

# Patch upstream schema bug: lh_departament CREATE TABLE is missing 9 columns
# that the ORM persistent object definition (pos/lhdepartament/...) declares.
# Without this, step3() fails with "Unknown column 'max_active_mails'" when
# inserting the default department. Bug present in 4.82..4.84 + master.
# Range-limited to the lh_departament block to avoid touching other tables.
sed -i '/CREATE TABLE IF NOT EXISTS `lh_departament`/,/) ENGINE=InnoDB CHARSET=utf8mb4 COLLATE=utf8mb4_unicode_ci\\";/ {
    s|^\(\s*\)`bot_configuration` text NOT NULL,$|\1`bot_configuration` text NOT NULL,\n\1`max_active_mails` int(11) NOT NULL DEFAULT 0,\n\1`active_mail_balancing` tinyint(1) NOT NULL DEFAULT 0,\n\1`max_ac_dep_mails` int(11) NOT NULL DEFAULT 0,\n\1`max_timeout_seconds_mail` int(11) NOT NULL DEFAULT 0,\n\1`delay_before_assign_mail` int(11) NOT NULL DEFAULT 0,\n\1`ignore_op_status` tinyint(1) NOT NULL DEFAULT 0,\n\1`dep_offline` tinyint(1) NOT NULL DEFAULT 0,\n\1`max_load_op` int(11) NOT NULL DEFAULT 0,\n\1`max_load_op_h` int(11) NOT NULL DEFAULT 0,|
}' "$install_dir/cli/lib/install.php"

# Patch upstream schema bug: lh_users CREATE TABLE is missing 2 columns
# (max_active_mails, exclude_autoasign_mails) that the ORM persistent object
# definition declares. Without this, step4() fails when inserting admin user.
# Range-limited to lh_users block to avoid touching other tables.
sed -i '/CREATE TABLE IF NOT EXISTS `lh_users`/,/) ENGINE=InnoDB CHARSET=utf8mb4 COLLATE=utf8mb4_unicode_ci;";/ {
    s|^\(\s*\)`exclude_autoasign` tinyint(1) NOT NULL,$|\1`exclude_autoasign` tinyint(1) NOT NULL,\n\1`exclude_autoasign_mails` tinyint(1) NOT NULL DEFAULT '\''0'\'',|
    s|^\(\s*\)`max_active_chats` int(11) NOT NULL,$|\1`max_active_chats` int(11) NOT NULL,\n\1`max_active_mails` int(11) NOT NULL DEFAULT 0,|
}' "$install_dir/cli/lib/install.php"

# Patch upstream schema bug: lh_rolefunction CREATE TABLE is missing `type` column
# that the ORM persistent object definition declares.
sed -i '/CREATE TABLE IF NOT EXISTS `lh_rolefunction`/,/) ENGINE=InnoDB CHARSET=utf8mb4 COLLATE=utf8mb4_unicode_ci;";/ {
    s|^\(\s*\)`limitation` text NOT NULL,$|\1`limitation` text NOT NULL,\n\1`type` int(11) NOT NULL DEFAULT 0,|
}' "$install_dir/cli/lib/install.php"

# install-cli.php uses relative paths, so it must be invoked from $install_dir
# cp inherits root ownership; chown so the $app user can read it under sudo
cp "$install_dir/cli/install-cli.php" "$install_dir/install-cli.php"
chown "$app:www-data" "$install_dir/install-cli.php"
chmod 644 "$install_dir/install-cli.php"

# Patch upstream bug: install-cli.php main() always exits with code 1 even on
# success, which trips ynh_abort_if_errors. Change exit(1) to exit(0) so the
# bash script can detect actual failures.
sed -i 's|^    exit(1);$|    exit(0);|' "$install_dir/install-cli.php"

# Settings file format per cli/lib/install.php: [db] + [admin] sections
cat > "$install_dir/cli/settings.ini" << EOF
[db]
host = "localhost"
port = "3306"
user = "$db_user"
password = "$db_pwd"
database = "$db_name"

[admin]
AdminUsername = "$admin"
AdminPassword = "$admin_password"
AdminEmail = "$admin_email"
AdminName = "$admin"
AdminSurname = "Admin"
DefaultDepartament = "Support"
EOF

chown "$app:www-data" "$install_dir/cli/settings.ini"
chmod 640 "$install_dir/cli/settings.ini"

pushd "$install_dir"
    sudo -u "$app" php${php_version} "$install_dir/install-cli.php" cli/settings.ini
popd

rm -f "$install_dir/install-cli.php"
rm -f "$install_dir/cli/settings.ini"

# CONFIGURE SETTINGS.INI.PHP
ynh_script_progression "Applying application settings..."

settings_file="$install_dir/settings/settings.ini.php"

if [ ! -f "$settings_file" ]; then
    cp "$install_dir/settings/settings.ini.default.php" "$settings_file"
fi

# Construct site_address: strip trailing slash from path if it's just "/" to avoid https://domain//
if [ "$path" = "/" ]; then
    site_address="https://$domain"
else
    site_address="https://$domain$path"
fi
sed -i "s|'site_address' => '.*'|'site_address' => '$site_address'|g" "$settings_file"

# Namespace the PHP session cookie to avoid conflicts
sed -i "s|php_session_cookie_name = .*|php_session_cookie_name = '${app}_session'|g" "$settings_file"

# Enable debug_output temporarily to surface real errors in browser
# (remove this once installation is confirmed working)
sed -i "s|'debug_output' => false|'debug_output' => true|" "$settings_file"

chown "$app:www-data" "$settings_file"
chmod 640 "$settings_file"

# Clear caches to ensure installed flag and settings are recognized
rm -rf "$install_dir/cache"/*
rm -rf "$install_dir/var/cacheconfig"/*

# Ensure cache subdirectories exist with proper permissions
mkdir -p "$install_dir/cache/cacheconfig"
mkdir -p "$install_dir/cache/compiledtemplates"
mkdir -p "$install_dir/cache/translations"
mkdir -p "$install_dir/cache/userinfo"
chmod 770 "$install_dir/cache/cacheconfig"
chmod 770 "$install_dir/cache/compiledtemplates"
chmod 770 "$install_dir/cache/translations"
chmod 770 "$install_dir/cache/userinfo"
chown -R "$app:www-data" "$install_dir/cache"
chown -R "$app:www-data" "$install_dir/var/cacheconfig"

# Diagnostic: confirm settings.ini.php has 'installed' => true and DB credentials
ynh_script_progression "Verifying settings.ini.php..."
if [ -f "$settings_file" ]; then
    grep -E "'installed'|'database'|'host'|'site_address'" "$settings_file" | head -10 || true
else
    echo "WARNING: settings.ini.php not found at $settings_file"
fi

# SETUP CRON JOB
ynh_script_progression "Setting up cron job..."

cp "../conf/lhc_cron" "/etc/cron.d/$app"
apply_template "/etc/cron.d/$app"
chmod 644 "/etc/cron.d/$app"

# END OF SCRIPT
ynh_script_progression "Installation of $app completed"
