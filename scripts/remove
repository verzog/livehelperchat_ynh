#!/bin/bash

set -u
source _common.sh
source /usr/share/yunohost/helpers
ynh_abort_if_errors

#=================================================
# REMOVE CRON JOB
#=================================================
ynh_script_progression "Removing cron job..."

rm -f "/etc/cron.d/$app"

#=================================================
# REMOVE PHP-FPM CONFIGURATION
#=================================================
ynh_script_progression "Removing PHP-FPM configuration..."

rm -f "/etc/php/$php_version/fpm/pool.d/$app.conf"
# Restart (not reload) to recover from a broken pool config left by a failed install
systemctl restart "php${php_version}-fpm" || true

#=================================================
# REMOVE NGINX CONFIGURATION
#=================================================
ynh_script_progression "Removing NGINX configuration..."

rm -f "/etc/nginx/conf.d/$domain.d/$app.conf"
systemctl reload nginx || true

#=================================================
# END OF SCRIPT
#=================================================
ynh_script_progression "Removal of $app completed"
