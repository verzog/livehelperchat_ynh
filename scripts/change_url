#!/bin/bash

set -u
source _common.sh
source /usr/share/yunohost/helpers
ynh_abort_if_errors

#=================================================
# MODIFY URL IN APP CONFIG
#=================================================
ynh_script_progression "Updating Live Helper Chat site address..."

settings_file="$install_dir/settings/settings.ini.php"

# LHC stores its base URL in the database; update settings.ini.php as a best-effort fallback
sed -i "s|site_address = .*|site_address = 'https://${new_domain}${new_path}/'|g" "$settings_file" || true

#=================================================
# UPDATE NGINX CONFIGURATION
#=================================================
ynh_script_progression "Updating NGINX web server configuration..."

mkdir -p "/etc/nginx/conf.d/$new_domain.d"
cp "../conf/nginx.conf" "/etc/nginx/conf.d/$new_domain.d/$app.conf"

apply_template "/etc/nginx/conf.d/$new_domain.d/$app.conf" "$new_domain" "$new_path"

# Remove old config if domain changed
if [ "$domain" != "$new_domain" ]; then
    rm -f "/etc/nginx/conf.d/$domain.d/$app.conf"
fi

systemctl reload nginx

#=================================================
# END OF SCRIPT
#=================================================
ynh_script_progression "Change of URL completed for $app"
