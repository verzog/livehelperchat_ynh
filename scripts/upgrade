#!/bin/bash

set -u
source _common.sh
source /usr/share/yunohost/helpers
ynh_abort_if_errors

#=================================================
# DOWNLOAD, CHECK AND UNPACK SOURCE
#=================================================
ynh_script_progression "Upgrading source files..."

ynh_setup_source --dest_dir="$install_dir" --keep="settings/settings.ini.php"

# The tarball extracts to install_dir/lhc_web/
# Move the actual application files to the install_dir root
if [ -d "$install_dir/lhc_web" ]; then
    # Use shopt to include hidden files in the glob pattern
    shopt -s dotglob
    mv "$install_dir/lhc_web"/* "$install_dir/" 2>/dev/null || true
    shopt -u dotglob
    rm -rf "$install_dir/lhc_web" || true
fi

chown -R "$app:www-data" "$install_dir"

#=================================================
# SET FOLDER PERMISSIONS
#=================================================
ynh_script_progression "Restoring folder permissions..."

chmod 755 "$install_dir/settings/"
chmod -R 775 "$install_dir/var/storage"
chmod -R 775 "$install_dir/var/userphoto"
chmod -R 775 "$install_dir/var/storageform"
chmod -R 775 "$install_dir/var/storageadmintheme"
chmod -R 775 "$install_dir/var/botphoto"
chmod -R 775 "$install_dir/var/bottrphoto"
chmod -R 775 "$install_dir/var/storageinvitation"
chmod -R 775 "$install_dir/var/storagedocshare"
chmod -R 775 "$install_dir/var/storagetheme"
chmod -R 775 "$install_dir/var/tmpfiles"
chmod -R 775 "$install_dir/cache/"

#=================================================
# RUN DATABASE UPGRADE
#=================================================
ynh_script_progression "Running database upgrade..."

pushd "$install_dir"
    ynh_exec_as_app php$php_version cron.php -s site_admin -c cron/util/update_database
    ynh_exec_as_app php$php_version cron.php -s site_admin -c cron/util/clear_cache -p 1
popd

#=================================================
# REAPPLY NGINX AND PHP-FPM CONFIGS
#=================================================
ynh_script_progression "Configuring PHP-FPM..."

mkdir -p "/etc/php/$php_version/fpm/pool.d"
cp "../conf/php-fpm.conf" "/etc/php/$php_version/fpm/pool.d/$app.conf"

ynh_replace --match="__NAME__" --replace="$app" --file="/etc/php/$php_version/fpm/pool.d/$app.conf"
ynh_replace --match="__APP__" --replace="$app" --file="/etc/php/$php_version/fpm/pool.d/$app.conf"
ynh_replace --match="__PHP_VERSION__" --replace="$php_version" --file="/etc/php/$php_version/fpm/pool.d/$app.conf"

ynh_systemctl --service="php${php_version}-fpm" --action=reload

ynh_script_progression "Configuring NGINX..."

mkdir -p "/etc/nginx/conf.d/$domain.d"
cp "../conf/nginx.conf" "/etc/nginx/conf.d/$domain.d/$app.conf"

ynh_replace --match="__INSTALL_DIR__" --replace="$install_dir" --file="/etc/nginx/conf.d/$domain.d/$app.conf"
ynh_replace --match="__PATH__" --replace="$path" --file="/etc/nginx/conf.d/$domain.d/$app.conf"
ynh_replace --match="__NAME__" --replace="$app" --file="/etc/nginx/conf.d/$domain.d/$app.conf"
ynh_replace --match="__PHP_VERSION__" --replace="$php_version" --file="/etc/nginx/conf.d/$domain.d/$app.conf"

ynh_systemctl --service=nginx --action=reload

#=================================================
# UPDATE CRON JOB
#=================================================
ynh_script_progression "Updating cron job..."

ynh_config_add --template="lhc_cron" --destination="/etc/cron.d/$app"

#=================================================
# END OF SCRIPT
#=================================================
ynh_script_progression "Upgrade of $app completed"
