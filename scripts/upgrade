#!/bin/bash

set -u
source _common.sh
source /usr/share/yunohost/helpers
ynh_abort_if_errors

# DOWNLOAD, CHECK AND UNPACK SOURCE
ynh_script_progression "Upgrading source files..."

ynh_setup_source --dest_dir="$install_dir" --keep="settings/settings.ini.php"

# The tarball extracts to install_dir/lhc_web/ — move contents up one level
if [ -d "$install_dir/lhc_web" ]; then
    shopt -s dotglob
    mv "$install_dir/lhc_web"/* "$install_dir/" 2>/dev/null || true
    shopt -u dotglob
    rm -rf "$install_dir/lhc_web"
fi

chown -R "$app:www-data" "$install_dir"

# SET FOLDER PERMISSIONS
ynh_script_progression "Setting folder permissions..."

# YunoHost standard: 770 for writable dirs (rwxrwx---)
# Allows both $app user and www-data (PHP) to read/write
chmod 770 "$install_dir/settings/"
chmod 770 "$install_dir/var/"
chmod -R 770 "$install_dir/var/storage"
chmod -R 770 "$install_dir/var/userphoto"
chmod -R 770 "$install_dir/var/storageform"
chmod -R 770 "$install_dir/var/storageadmintheme"
chmod -R 770 "$install_dir/var/botphoto"
chmod -R 770 "$install_dir/var/bottrphoto"
chmod -R 770 "$install_dir/var/storageinvitation"
chmod -R 770 "$install_dir/var/storagedocshare"
chmod -R 770 "$install_dir/var/storagetheme"
chmod -R 770 "$install_dir/var/tmpfiles"
chmod -R 770 "$install_dir/cache/"

# RUN DATABASE UPGRADE
ynh_script_progression "Running database upgrade..."

pushd "$install_dir"
    # Database updates are non-blocking — they're nice to have but optional
    sudo -u "$app" php${php_version} cron.php -s site_admin -c cron/util/update_database || true
    sudo -u "$app" php${php_version} cron.php -s site_admin -c cron/util/clear_cache -p 1 || true
popd

# Create missing lh_abstract_proactive_chat_invitation_one_time table if it doesn't exist
mysql -u "$db_user" -p"$db_pwd" "$db_name" << 'SQLEOF'
CREATE TABLE IF NOT EXISTS `lh_abstract_proactive_chat_invitation_one_time` (
  `id` bigint(20) NOT NULL AUTO_INCREMENT,
  `visitor_id` bigint(20) NOT NULL,
  `chat_id` bigint(20) DEFAULT NULL,
  `chat_variables` longtext,
  `invited_date` bigint(20) NOT NULL,
  `invited` tinyint(1) NOT NULL DEFAULT 0,
  `accepted` tinyint(1) NOT NULL DEFAULT 0,
  PRIMARY KEY (`id`),
  KEY `visitor_id` (`visitor_id`),
  KEY `chat_id` (`chat_id`),
  KEY `invited_date` (`invited_date`)
) ENGINE=InnoDB CHARSET=utf8mb4 COLLATE=utf8mb4_unicode_ci;
SQLEOF

# PHP-FPM CONFIGURATION
ynh_script_progression "Configuring PHP-FPM..."

mkdir -p "/etc/php/$php_version/fpm/pool.d"
cp "../conf/php-fpm.conf" "/etc/php/$php_version/fpm/pool.d/$app.conf"
apply_template "/etc/php/$php_version/fpm/pool.d/$app.conf"

php-fpm${php_version} --test 2>/dev/null \
    || { rm -f "/etc/php/$php_version/fpm/pool.d/$app.conf"; ynh_die "PHP-FPM config test failed — pool config removed to protect other sites."; }

systemctl reload "php${php_version}-fpm"

# NGINX CONFIGURATION
ynh_script_progression "Configuring NGINX web server..."

mkdir -p "/etc/nginx/conf.d/$domain.d"
cp "../conf/nginx.conf" "/etc/nginx/conf.d/$domain.d/$app.conf"
apply_template "/etc/nginx/conf.d/$domain.d/$app.conf"

systemctl reload nginx

# UPDATE CRON JOB
ynh_script_progression "Updating cron job..."

cp "../conf/lhc_cron" "/etc/cron.d/$app"
apply_template "/etc/cron.d/$app"
chmod 644 "/etc/cron.d/$app"

# END OF SCRIPT
ynh_script_progression "Upgrade of $app completed"
